# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Service Principal (Entra ID) for Azure OpenAI authentication
AZURE_SP_TENANT_ID=your-tenant-id-here
AZURE_SP_CLIENT_ID=your-client-id-here
AZURE_SP_CLIENT_SECRET=your-client-secret-here

# Model deployment names
AZURE_OPENAI_ORCHESTRATOR_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_PLANNER_DEPLOYMENT=o3

# Azure Speech Services
AZURE_SPEECH_KEY=your-speech-key-here
AZURE_SPEECH_REGION=australiaeast
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# Azure AI Search (Phase 2 — Memory Agent)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key-here
AZURE_SEARCH_INDEX=ringo-memory

# Azure OpenAI Embedding (Phase 2 — Memory Agent)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Safety Settings
MAX_MOTOR_SPEED=75
OBSTACLE_STOP_DISTANCE_MM=150
MAX_SESSION_MINUTES=15

# Hardware
VOICE_MODULE_PORT=/dev/ttyUSB0
VOICE_MODULE_BAUD=115200
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
